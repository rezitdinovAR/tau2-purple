{
  manifest_version: "0.1.0",

  // Config supplied by the deployer (AgentBeats UI / Amber scenario).
  // The agent reads these values from environment variables at runtime.
  config_schema: {
    type: "object",
    properties: {
      openrouter_api_key:    { type: "string", secret: true },
      agent_llm: {
        type: "string",
        description: "litellm model id (e.g. openai/gpt-4.1, anthropic/claude-sonnet-4-5)",
        default: "openai/gpt-4.1",
      },
      agent_temperature: {
        type: "string",
        description: "Sampling temperature for the agent LLM",
        default: "0.0",
      },
    },
    // Only one provider key is strictly required — leave the other blank if unused.
    required: [],
    additionalProperties: false,
  },

  // External services this agent uses.
  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  // Runtime configuration.
  program: {
    image: "ghcr.io/rezitdinovar/tau2-purple:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",

    // Pass config values through to the container as environment variables.
    env: {
      OPENROUTER_API_KEY:       "${config.openrouter_api_key}",
      TAU2_AGENT_LLM:           "${config.agent_llm}",
      TAU2_AGENT_TEMPERATURE:   "${config.agent_temperature}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 }, // must match --port in entrypoint
      ],
    },
  },

  // Capabilities provided by this agent.
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  // Capabilities exposed to the scenario.
  exports: { a2a: "a2a" },
}
